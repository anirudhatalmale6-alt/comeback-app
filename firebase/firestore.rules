rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAuth();
    }

    match /connection_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    match /page_alerts/{alertId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    match /chat_rooms/{roomId} {
      allow read, write: if isAuth();

      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }

    match /salons/{salonId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
    }

    match /salon_photos/{photoId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }

    match /business_hours/{hourId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
    }

    match /services/{serviceId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    match /employee_schedules/{scheduleId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
    }

    match /schedule_requests/{requestId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
    }

    match /customer_nail_photos/{photoId} {
      allow read: if isAuth();
      allow create, delete: if isAuth();
    }

    match /password_reset_tokens/{tokenId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
    }

    // Virtual Nail Try-On design library.
    // Any signed-in user can browse. Uploads are allowed for signed-in users
    // (salons/admin); a design can only be deleted by the account that created it.
    match /nail_designs/{designId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.uploadedByUserId == request.auth.uid;
      allow delete: if isAuth()
                    && resource.data.uploadedByUserId == request.auth.uid;
    }
  }
}
